# ================================================================================
# PDF Translator - Environment Configuration
# ================================================================================
#
# Setup Instructions:
#   1. cp .env.example .env
#   2. Fill in your values below
#   3. source .env
#   4. export GITHUB_TOKEN=$(grep GITHUB_TOKEN .env | cut -d= -f2)
#   5. export GITHUB_REPO=$(grep GITHUB_REPO .env | cut -d= -f2)
#   6. gh auth status
#
# ================================================================================

# Node Environment
NODE_ENV=development

# Server
PORT=3000

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Translation Service
DEEPL_API_KEY=
GOOGLE_TRANSLATE_API_KEY=

# GitHub Configuration (Project-Specific Fine-Grained Token)
# Generate at: https://github.com/settings/personal-access-tokens
# Permissions: Contents (R&W), Pull requests (R&W)
GITHUB_TOKEN=
GITHUB_REPO=
